# =============================================================
# INEXCI API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
#
# Obs.: Se for subir via `docker-compose up -d` na raiz do repo,
# também é preciso o `.env` na raiz com POSTGRES_USER,
# POSTGRES_PASSWORD, POSTGRES_DB. Ver `.env.example` da raiz.
# =============================================================

# ===================================
# CORE
# ===================================
# OBRIGATÓRIO: deve ser "production" em produção
NODE_ENV=production
PORT=3000
# OBRIGATÓRIO: connection string do PostgreSQL (precisa ter pgvector)
DATABASE_URL=postgresql://inexci_user:SENHA_SEGURA@db:5432/inexci

# ===================================
# AUTH (JWT)
# ===================================
# OBRIGATÓRIO: gere com `openssl rand -base64 64`
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_E_SEGURA
# OBRIGATÓRIO: emissor esperado nos tokens (claim `iss`)
JWT_ISSUER=inexci-api
# OBRIGATÓRIO: audiência esperada nos tokens (claim `aud`)
JWT_AUDIENCE=inexci-app

# ===================================
# SECURITY (criptografia / hash)
# ===================================
# Chave AES-256-GCM para colunas criptografadas via TypeORM transformer.
# OBRIGATÓRIO em produção: gere com `openssl rand -hex 32` (32 bytes / 64 chars hex).
# Sem esta chave, dados sensíveis ficam em texto puro no banco.
DB_ENCRYPTION_KEY=
# Salt para hash de telefones (LGPD).
# OBRIGATÓRIO em produção: gere com `openssl rand -hex 32`. Sem isso usa fallback fraco.
PHONE_HASH_SALT=

# ===================================
# CORS
# ===================================
# OBRIGATÓRIO em produção: URL(s) do frontend separadas por vírgula
CORS_ORIGINS=https://app.inexci.com.br,https://api.inexci.com.br

# ===================================
# FRONTEND
# ===================================
# OBRIGATÓRIO: URL pública do dashboard (usada em e-mails e na notice de consent)
DASHBOARD_URL=https://app.inexci.com.br

# ===================================
# SUPABASE (Storage)
# ===================================
# Use as novas API keys do Supabase (em Project Settings → API Keys).
# As chaves antigas (anon / service_role) foram substituídas por:
#   - Publishable key (sb_publishable_...) → usada no cliente público (RLS aplicado)
#   - Secret key       (sb_secret_...)     → usada no backend para bypass de RLS (storage)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
# OBRIGATÓRIO: nome exato do bucket privado no Supabase Storage
SUPABASE_BUCKET=

# ===================================
# E-MAIL (SMTP)
# ===================================
MAIL_HOST=smtps.uhserver.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=seu_email@dominio.com
MAIL_PASS=sua_senha_smtp
MAIL_FROM_NAME=Inexci
MAIL_FROM_ADDRESS=no-reply@inexci.com.br

# ===================================
# REDIS (filas + estado distribuído)
# ===================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=seu_usuario
REDIS_PASSWORD=sua_senha
REDIS_TLS=true

# ===================================
# BULL BOARD (login da rota /admin/queues)
# ===================================
BULL_BOARD_USER=
BULL_BOARD_PASS=

# ===================================
# TWILIO (WhatsApp Business)
# ===================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Em produção, usar o número aprovado no WhatsApp Business (não o sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+XXXXXXXXXXX
# Webhook do Twilio: configurado direto no console da Twilio.
# Aponte para: https://<sua-api>/webhooks/twilio
# Validação de assinatura HMAC do webhook Twilio (RECOMENDADO em produção)
TWILIO_VALIDATE_SIGNATURE=true

# ===================================
# OPENAI
# ===================================
OPENAI_API_KEY=sk-...
# Modelo principal do assistente WhatsApp (orchestrator + sumarizador).
# gpt-5-mini: qualidade GPT-5 a custo próximo do gpt-4.1-mini ($0,25/$2,00 por 1M tokens).
# Fallback estável comprovado: gpt-4o-mini ($0,15/$0,60).
OPENAI_MODEL=gpt-5-mini
# Modelo de embeddings para o RAG. Não troque sem reindexar todos os chunks.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Timeout (ms) das chamadas à OpenAI (chat/embedding).
OPENAI_REQUEST_TIMEOUT_MS=25000

# ===================================
# AI — CONFIGURAÇÃO DA CONVERSA
# ===================================
# Tempo de inatividade antes de iniciar uma nova sessão de conversa (minutos).
AI_SESSION_TIMEOUT_MINUTES=60

# ── Janela de contexto ───────────────────────────────────────────────────────
# AI_MAX_RECENT_MESSAGES: quantas mensagens completas são enviadas ao LLM por turno.
# AI_SUMMARY_TRIGGER_EVERY_MESSAGES: a cada N novas mensagens, regenera o summary.
#   Regra: trigger ≤ max/2 → zero gap entre summary e janela recente.
#   Com max=15 e trigger=5: summary cobre até -5 msgs, recent cobre -15 a agora (10 de overlap).
# AI_CONTEXT_TOKEN_BUDGET: teto de tokens do contexto (system+summary+memory+RAG+recent).
#   Overhead fixo estimado: ~2.400 tokens. 15 msgs ≈ 1.500 tokens. Total real ≈ 3.900.
#   4.500 = 3.900 + ~15% de margem. Quando estoura, corta: RAG → recentes (mínimo 3) → summary.
# AI_SUMMARY_MAX_TOKENS: tamanho máximo do summary gerado.
#   550 acomoda SCs com múltiplos TUSS, CID e itens OPME sem truncar.
AI_MAX_RECENT_MESSAGES=15
AI_SUMMARY_TRIGGER_EVERY_MESSAGES=5
AI_SUMMARY_MAX_TOKENS=550
AI_CONTEXT_TOKEN_BUDGET=4500

# ── Resposta ─────────────────────────────────────────────────────────────────
# Limite de tokens da resposta do LLM. 500 cobre respostas completas no WhatsApp
# sem desperdiçar output (o custo do output é 4x maior que o input no gpt-4o-mini).
AI_RESPONSE_MAX_TOKENS=500

# ── Timeouts e retenção ───────────────────────────────────────────────────────
# Timeout (ms) total do processamento de UMA mensagem pelo orchestrator.
AI_PROCESS_TIMEOUT_MS=90000
# URL de consentimento é derivada automaticamente de DASHBOARD_URL + /configuracoes/privacidade.
# Dias de inatividade antes de apagar o histórico de conversa (cron diário às 3h).
CONVERSATION_CLEANUP_DAYS=15

# ===================================
# IA WhatsApp (Áudio / STT)
# ===================================
# Habilita processamento de áudio inbound no WhatsApp.
AI_AUDIO_ENABLED=true
# Provider de transcrição: faster_whisper (self-host) | openai
AI_TRANSCRIPTION_PROVIDER=openai
# Timeout (ms) da transcrição.
AI_TRANSCRIPTION_TIMEOUT_MS=30000
# Fallback entre providers (recomendado false quando usar apenas OpenAI).
AI_STT_ENABLE_FALLBACK=false

# OpenAI STT
AI_STT_OPENAI_MODEL=gpt-4o-mini-transcribe
AI_STT_OPENAI_URL=https://api.openai.com/v1/audio/transcriptions

# Faster-whisper self-host (opcional)
AI_STT_FASTER_WHISPER_URL=http://stt-service:8000

# Limites de segurança de áudio inbound
AI_AUDIO_ALLOWED_MIME=audio/ogg,audio/mpeg,audio/mp4,audio/webm,audio/wav,audio/x-wav
AI_AUDIO_MAX_BYTES=15728640
AI_AUDIO_MAX_DURATION_SECONDS=300
AI_AUDIO_DOWNLOAD_TIMEOUT_MS=15000

# Persistência opcional de debug (desativada por padrão)
AI_AUDIO_DEBUG_PERSIST=false
AI_AUDIO_DEBUG_DIR=/tmp/inexci-audio-debug
AI_AUDIO_DEBUG_RETENTION_HOURS=24

# ===================================
# IA WhatsApp (Documentos / OCR)
# ===================================
# Liga/desliga todo o pipeline de imagens e PDFs inbound no WhatsApp.
AI_DOC_ENABLED=true
# Tamanho máximo em bytes do documento aceito (default 10 MB).
AI_DOC_MAX_BYTES=10485760
# Whitelist de MIME aceitos (separados por vírgula).
AI_DOC_ALLOWED_IMAGE_MIME=image/jpeg,image/jpg,image/png,image/webp
AI_DOC_ALLOWED_PDF_MIME=application/pdf
# Limite de páginas para PDFs antes de recusar.
AI_DOC_MAX_PAGES=5
# Por quanto tempo a "pendência por telefone" sobrevive enquanto aguarda
# a intent do usuário (1=anexar, 2=criar SC, 3=cadastrar paciente).
AI_DOC_PENDING_TTL_MINUTES=10
# Pasta no Supabase Storage usada como staging.
AI_DOC_TMP_FOLDER=whatsapp-tmp
# Janela de retenção da pasta tmp (cron horário apaga arquivos mais antigos).
AI_DOC_TMP_RETENTION_HOURS=1
# Idioma do Tesseract.
AI_DOC_OCR_LANG=por
# Modelo do classificador de documento (JSON schema strict).
# gpt-5-nano: geração 5 no modelo mais barato ($0,05/$0,40 por 1M tokens).
# Fallback estável: gpt-4.1-nano ou gpt-4o-mini.
AI_DOC_CLASSIFIER_MODEL=gpt-5-nano
# Fallback Vision quando OCR falha (imagens ilegíveis, documentos manuscritos).
AI_DOC_VISION_FALLBACK_ENABLED=true
# gpt-4.1: mais novo, mais capaz e mais barato que gpt-4o ($2,00/$8,00 vs $2,50/$10,00).
AI_DOC_VISION_FALLBACK_MODEL=gpt-4.1

# ===================================
# STRIPE (Gateway de Pagamento)
# ===================================
# Chave secreta da conta Stripe (painel → Developers → API keys).
# OBRIGATÓRIO: sem esta chave o módulo de billing não funciona.
STRIPE_SECRET_KEY=sk_live_...
# Segredo de webhook do Stripe (painel → Developers → Webhooks → Signing secret).
# OBRIGATÓRIO para validar eventos recebidos em POST /billing/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=whsec_...
# Timeout (ms) das chamadas à API do Stripe.
STRIPE_REQUEST_TIMEOUT_MS=15000

# ===================================
# PUPPETEER (PDF generation) — opcional
# ===================================
# Caminho do binário do Chromium (default: bundled). Útil em ambientes restritos.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ===================================
# LOGGING / OBSERVABILIDADE
# ===================================
# Nível mínimo dos logs: error | warn | log | debug | verbose
LOG_LEVEL=log
# Output legível com cores em vez de JSON (default: true em dev, false em prod).
# Aceita 'true'/'false' — vazio = auto (true se NODE_ENV=development).
LOG_PRETTY=
# Retenção (em dias) das tabelas de log persistido. O cron diário às 04:00
# (America/Sao_Paulo) apaga linhas mais antigas que esses prazos.
LOG_RETENTION_NOTIFICATION_DAYS=90
LOG_RETENTION_AI_USAGE_DAYS=365
LOG_RETENTION_PII_DAYS=180
LOG_RETENTION_STALE_DAYS=60

# ===================================
# OPENTELEMETRY (tracing distribuído)
# ===================================
# Endpoint OTLP do coletor (Grafana Cloud Tempo, Jaeger, etc.).
# Se omitido: traces são descartados (NoopSpanProcessor).
# Formato Grafana Cloud: https://tempo-prod-XX-prod-XX.grafana.net/tempo/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# Credenciais do coletor (Grafana Cloud exige Basic auth em base64).
# Formato: Authorization=Basic <base64(instanceId:token)>
OTEL_EXPORTER_OTLP_HEADERS=
# Fração de traces amostrados: 1.0 = 100%, 0.1 = 10% (default prod).
OTEL_TRACES_SAMPLER_ARG=1.0
