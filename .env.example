# =============================================================
# INEXCI API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
#
# Obs.: Se for subir via `docker-compose up -d` na raiz do repo,
# também é preciso o `.env` na raiz com POSTGRES_USER,
# POSTGRES_PASSWORD, POSTGRES_DB. Ver `.env.example` da raiz.
# =============================================================

# ===================================
# CORE
# ===================================
# OBRIGATÓRIO: deve ser "production" em produção
NODE_ENV=production
PORT=3000
# OBRIGATÓRIO: connection string do PostgreSQL (precisa ter pgvector)
DATABASE_URL=postgresql://inexci_user:SENHA_SEGURA@db:5432/inexci

# ===================================
# AUTH (JWT)
# ===================================
# OBRIGATÓRIO: gere com `openssl rand -base64 64`
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_E_SEGURA

# ===================================
# SECURITY (criptografia / hash)
# ===================================
# Chave AES-256-GCM para colunas criptografadas via TypeORM transformer.
# OBRIGATÓRIO em produção: gere com `openssl rand -hex 32` (32 bytes / 64 chars hex).
# Sem esta chave, dados sensíveis ficam em texto puro no banco.
DB_ENCRYPTION_KEY=
# Salt para hash de telefones (LGPD).
# OBRIGATÓRIO em produção: gere com `openssl rand -hex 32`. Sem isso usa fallback fraco.
PHONE_HASH_SALT=

# ===================================
# CORS
# ===================================
# OBRIGATÓRIO em produção: URL(s) do frontend separadas por vírgula
CORS_ORIGINS=https://app.inexci.com.br,https://api.inexci.com.br

# ===================================
# FRONTEND
# ===================================
# OBRIGATÓRIO: URL pública do dashboard (usada em e-mails e na notice de consent)
DASHBOARD_URL=https://app.inexci.com.br

# ===================================
# SUPABASE (Storage)
# ===================================
# Use as novas API keys do Supabase (em Project Settings → API Keys).
# As chaves antigas (anon / service_role) foram substituídas por:
#   - Publishable key (sb_publishable_...) → usada no cliente público (RLS aplicado)
#   - Secret key       (sb_secret_...)     → usada no backend para bypass de RLS (storage)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
# OBRIGATÓRIO: nome exato do bucket privado no Supabase Storage
SUPABASE_BUCKET=

# ===================================
# E-MAIL (SMTP)
# ===================================
MAIL_HOST=smtps.uhserver.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=seu_email@dominio.com
MAIL_PASS=sua_senha_smtp
MAIL_FROM_NAME=Inexci
MAIL_FROM_ADDRESS=no-reply@inexci.com.br

# ===================================
# REDIS (filas + estado distribuído)
# ===================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=seu_usuario
REDIS_PASSWORD=sua_senha
REDIS_TLS=true

# ===================================
# BULL BOARD (login da rota /admin/queues)
# ===================================
BULL_BOARD_USER=
BULL_BOARD_PASS=

# ===================================
# TWILIO (WhatsApp Business)
# ===================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Em produção, usar o número aprovado no WhatsApp Business (não o sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+XXXXXXXXXXX
# Webhook do Twilio: configurado direto no console da Twilio.
# Aponte para: https://<sua-api>/webhooks/twilio
# Validação de assinatura HMAC do webhook Twilio (RECOMENDADO em produção)
TWILIO_VALIDATE_SIGNATURE=true

# ===================================
# OPENAI
# ===================================
OPENAI_API_KEY=sk-...
# Modelo principal do assistente WhatsApp (orchestrator + sumarizador).
# gpt-5-mini: qualidade GPT-5 a custo próximo do gpt-4.1-mini ($0,25/$2,00 por 1M tokens).
# Fallback estável comprovado: gpt-4o-mini ($0,15/$0,60).
OPENAI_MODEL=gpt-5-mini
# Modelo de embeddings para o RAG. Não troque sem reindexar todos os chunks.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===================================
# AI MODEL GATEWAY (tiers — Fase 1 Blueprint v3)
# ===================================
# Resolução por tier. Formato: <provider>:<model>[:<apiKind>]
# Quando ausente, usa default em `model-tier.types.ts`.
#
# ┌─────────────┬──────────────────────────────────────────────────┬─────────────────────────┐
# │ Tier        │ Usado em                                         │ Modelo recomendado       │
# ├─────────────┼──────────────────────────────────────────────────┼─────────────────────────┤
# │ cheap       │ planner, intent classifier, doc classifier,      │ gpt-4o-mini              │
# │             │ summarizer, STT entity extraction,               │ ($0,15/$0,60 por 1M tok) │
# │             │ semantic compression de áudio longo              │                          │
# ├─────────────┼──────────────────────────────────────────────────┼─────────────────────────┤
# │ standard    │ orchestrator do turno (decide qual tool chamar)  │ gpt-4.1                  │
# │             │                                                  │ ($2/$8 por 1M tok)       │
# │             │ ↳ Com AI_PROMPT_V3+AI_PLANNER_V3 ativos, o       │ vs gpt-4o ($2,50/$10)    │
# │             │   orchestrator recebe prompt enxuto + 5-15 tools │                          │
# │             │   em vez de 56 → pode usar modelo mais econômico │                          │
# ├─────────────┼──────────────────────────────────────────────────┼─────────────────────────┤
# │ premium     │ Fallback RARO: loops > 3 iterações, casos que    │ gpt-4o                   │
# │             │ o standard não conseguiu resolver                │ (reserva; custo alto)    │
# ├─────────────┼──────────────────────────────────────────────────┼─────────────────────────┤
# │ vision      │ OCR fallback final (doc ilegível, manuscrito).   │ gpt-4.1                  │
# │             │ Com AI_OCR_V3 ativo, só chega aqui ~5% dos docs. │ (melhor custo que gpt-4o)│
# ├─────────────┼──────────────────────────────────────────────────┼─────────────────────────┤
# │ embedding   │ RAG e semantic memory. Não troque sem reindexar. │ text-embedding-3-small   │
# │             │                                                  │ ($0,02 por 1M tok)       │
# └─────────────┴──────────────────────────────────────────────────┴─────────────────────────┘
#
# ATENÇÃO: se quiser adotar gpt-4.1-mini no standard (mais barato ainda que gpt-4.1),
# teste em staging primeiro — suporte a parallel tool calls e complex reasoning
# é inferior ao gpt-4.1 em fluxos multi-step (criar SC + enviar + confirmar no mesmo turno).
AI_TIER_CHEAP=openai:gpt-4o-mini:chat_completions
AI_TIER_STANDARD=openai:gpt-4.1:chat_completions
AI_TIER_PREMIUM=openai:gpt-4o:chat_completions
AI_TIER_VISION=openai:gpt-4.1:chat_completions
AI_TIER_EMBEDDING=openai:text-embedding-3-small:embeddings

# ───────────────────────────────────────────────────────────────────────────
# Feature flags do Blueprint v3
# ───────────────────────────────────────────────────────────────────────────
# PRÉ-REQUISITO: antes de ligar qualquer flag, aplique as migrations:
#   yarn typeorm:migration:run
# Migrations novas: AddAiTelemetryColumns, CreateAiDocCache,
#                   CreateAiPersistentMemory, AddTsvectorToAiKnowledgeChunks
#
# ORDEM RECOMENDADA DE ROLLOUT (do menor risco ao maior):
#   1. AI_OCR_V3      → maior ROI imediato, sem alterar comportamento conversacional
#   2. AI_STT_V3      → cache puro, transparente para o usuário
#   3. AI_MEMORY_V3   → estabiliza memória estruturada (elimina regressões de confirmação)
#   4. AI_PROMPT_V3   → ligar JUNTO com AI_PLANNER_V3 (os dois são complementares)
#   5. AI_PLANNER_V3  → idem
#   6. AI_RAG_HYBRID  → ligar após validar BM25 com queries reais em staging
#   7. AI_WORKFLOW_ENGINE → último; refator estrutural, baixo impacto funcional visível
# ───────────────────────────────────────────────────────────────────────────

# Slim prompt (core.prompt.ts ≤40 linhas) + Operational State JSON + módulos de workflow.
# Reduz overhead do system prompt de ~600 para ~150 tokens por turno.
# Habilita o prompt cache da OpenAI (prefixo estável → desconto automático).
AI_PROMPT_V3=true

# Planner explícito: classifica intenção antes de chamar o orchestrator.
# Reduz as tools enviadas de 56 para 5-15 (-60% nos input tokens da iteração 1).
# Requer AI_PROMPT_V3=true para efeito máximo.
AI_PLANNER_V3=true

# Pipeline STT redesenhado: deduplicação SHA256 + glossário médico + entity extraction.
# Áudio idêntico a um anterior = 0 custo. Áudio longo = resumo semântico ao orchestrator.
AI_STT_V3=true

# Pipeline OCR redesenhado: cache SHA256 + parsers determinísticos + confidence engine.
# ~80% dos documentos processados sem OpenAI Vision. Documento reenviado = 0 tokens.
# Requer migration CreateAiDocCache aplicada.
AI_OCR_V3=true

# Memória 3-camadas: RecentMessageSelector priorizado + persistent memory + patch-only.
# Elimina o bug de "IA esqueceu a confirmação pendente depois do resumo".
# Requer migration CreateAiPersistentMemory aplicada.
AI_MEMORY_V3=true

# RAG híbrido: BM25 (full-text) + cosine (semântica) fundidos via RRF.
# Melhora recall em consultas factuais curtas sem custo adicional de API.
# Requer migration AddTsvectorToAiKnowledgeChunks aplicada.
AI_RAG_HYBRID=true

# Workflow Engine: fachada única para as 13 transições de SC.
# Impacto funcional zero para o usuário; simplifica manutenção futura.
AI_WORKFLOW_ENGINE=true

# Timeout (ms) das chamadas à OpenAI. 20s é suficiente com gpt-4.1;
# 25s era necessário com gpt-4o que tem maior latência de primeiro token.
OPENAI_REQUEST_TIMEOUT_MS=20000

# ===================================
# AI — CONFIGURAÇÃO DA CONVERSA
# ===================================
# Tempo de inatividade antes de iniciar uma nova sessão de conversa (minutos).
AI_SESSION_TIMEOUT_MINUTES=60

# ── Janela de contexto ───────────────────────────────────────────────────────
# COM AI_PROMPT_V3 + AI_PLANNER_V3 + AI_MEMORY_V3 ATIVOS, os orçamentos mudam:
#
# AI_MAX_RECENT_MESSAGES: com RecentMessageSelector priorizado, 10 mensagens
#   bem escolhidas valem mais que 15 em slice puro. Reduz ~300 tokens/turno.
#
# AI_SUMMARY_TRIGGER_EVERY_MESSAGES: com patch-only memory, a memória
#   estruturada é mantida por handlers determinísticos — não precisa regenerar
#   summary a cada 5 mensagens. 8 é o novo equilíbrio estável.
#
# AI_CONTEXT_TOKEN_BUDGET: com slim prompt (~800 tok de overhead vs ~2.400 antes)
#   e menos mensagens recentes, 3.500 cobre com folga:
#   overhead ~800 + summary ~400 + memory ~200 + RAG ~300 + 10 msgs ~1.000 = ~2.700
#   3.500 = 2.700 + ~30% de margem.
#
# AI_SUMMARY_MAX_TOKENS: com patch-only, o summary é apenas texto legível
#   (memória estruturada não mora mais no summary). 400 tok é suficiente.
AI_MAX_RECENT_MESSAGES=10
AI_SUMMARY_TRIGGER_EVERY_MESSAGES=8
AI_SUMMARY_MAX_TOKENS=400
AI_CONTEXT_TOKEN_BUDGET=3500

# ── RAG ────────────────────────────────────────────────────────────────────
# Com RAG híbrido, o BM25 cobre consultas factuais que o cosine perde.
# Podemos aceitar score cosine menor (0,45) porque a fusão RRF compensa.
# Valor anterior: 0,65 (só cosine) era conservador para evitar ruído.
AI_RAG_TOP_K=4
AI_RAG_MIN_SCORE=0.45

# ── Resposta ─────────────────────────────────────────────────────────────────
# Output é ~4x mais caro que input na OpenAI. Respostas de WhatsApp são curtas.
# 380 tokens = ~1.900 caracteres = mensagem WhatsApp longa com margem de segurança.
# Com AI_PROMPT_V3 ativo o modelo já sabe limitar ao formato WhatsApp naturalmente.
AI_RESPONSE_MAX_TOKENS=380

# ── Timeouts e retenção ───────────────────────────────────────────────────────
# Timeout (ms) total do processamento de UMA mensagem pelo orchestrator.
AI_PROCESS_TIMEOUT_MS=90000
# URL de consentimento é derivada automaticamente de DASHBOARD_URL + /configuracoes/privacidade.
# Dias de inatividade antes de apagar o histórico de conversa (cron diário às 3h).
CONVERSATION_CLEANUP_DAYS=15

# ===================================
# IA WhatsApp (Áudio / STT)
# ===================================
# Habilita processamento de áudio inbound no WhatsApp.
AI_AUDIO_ENABLED=true

# Provider de transcrição primário.
# faster_whisper = self-hosted, custo zero de API (só infra).
# openai         = pago por minuto de áudio.
# COM AI_STT_V3=true: o cache SHA256 evita retranscrição de áudios repetidos
# independente do provider escolhido.
# RECOMENDAÇÃO: usar faster_whisper como primário + fallback para OpenAI.
AI_TRANSCRIPTION_PROVIDER=faster_whisper

# Timeout (ms) da transcrição. faster_whisper local é mais rápido.
AI_TRANSCRIPTION_TIMEOUT_MS=20000

# COM faster_whisper como primário, o fallback para OpenAI cobre quedas do stt-service.
AI_STT_ENABLE_FALLBACK=true

# OpenAI STT (usado apenas como fallback com a configuração acima)
# gpt-4o-mini-transcribe: mais barato que whisper-1 e mais preciso em pt-BR.
AI_STT_OPENAI_MODEL=gpt-4o-mini-transcribe
AI_STT_OPENAI_URL=https://api.openai.com/v1/audio/transcriptions

# Faster-whisper self-host
AI_STT_FASTER_WHISPER_URL=http://stt-service:8000

# Limites de segurança de áudio inbound
# 10 MB é suficiente para áudios de WhatsApp (mensagens de voz chegam em OGG ~1MB/min).
# 15 MB era margem excessiva.
AI_AUDIO_ALLOWED_MIME=audio/ogg,audio/mpeg,audio/mp4,audio/webm,audio/wav,audio/x-wav
AI_AUDIO_MAX_BYTES=10485760
AI_AUDIO_MAX_DURATION_SECONDS=300
AI_AUDIO_DOWNLOAD_TIMEOUT_MS=15000

# Persistência opcional de debug (desativada por padrão)
AI_AUDIO_DEBUG_PERSIST=false
AI_AUDIO_DEBUG_DIR=/tmp/inexci-audio-debug
AI_AUDIO_DEBUG_RETENTION_HOURS=24

# ===================================
# IA WhatsApp (Documentos / OCR)
# ===================================
# Liga/desliga todo o pipeline de imagens e PDFs inbound no WhatsApp.
AI_DOC_ENABLED=true
# Tamanho máximo em bytes do documento aceito (default 10 MB).
AI_DOC_MAX_BYTES=10485760
# Whitelist de MIME aceitos (separados por vírgula).
AI_DOC_ALLOWED_IMAGE_MIME=image/jpeg,image/jpg,image/png,image/webp
AI_DOC_ALLOWED_PDF_MIME=application/pdf
# Limite de páginas para PDFs antes de recusar.
AI_DOC_MAX_PAGES=5
# Por quanto tempo a "pendência por telefone" sobrevive enquanto aguarda
# a intent do usuário (1=anexar, 2=criar SC, 3=cadastrar paciente).
AI_DOC_PENDING_TTL_MINUTES=10
# Pasta no Supabase Storage usada como staging.
AI_DOC_TMP_FOLDER=whatsapp-tmp
# Janela de retenção da pasta tmp (cron horário apaga arquivos mais antigos).
AI_DOC_TMP_RETENTION_HOURS=1
# Idioma do Tesseract.
AI_DOC_OCR_LANG=por
# Modelo do classificador de documento (JSON schema strict).
# gpt-5-nano: geração 5 no modelo mais barato ($0,05/$0,40 por 1M tokens).
# Fallback estável: gpt-4.1-nano ou gpt-4o-mini.
AI_DOC_CLASSIFIER_MODEL=gpt-5-nano
# Fallback Vision quando OCR falha (imagens ilegíveis, documentos manuscritos).
AI_DOC_VISION_FALLBACK_ENABLED=true
# gpt-4.1: mais novo, mais capaz e mais barato que gpt-4o ($2,00/$8,00 vs $2,50/$10,00).
AI_DOC_VISION_FALLBACK_MODEL=gpt-4.1

# ===================================
# STRIPE (Gateway de Pagamento)
# ===================================
# Chave secreta da conta Stripe (painel → Developers → API keys).
# OBRIGATÓRIO: sem esta chave o módulo de billing não funciona.
STRIPE_SECRET_KEY=sk_live_...
# Segredo de webhook do Stripe (painel → Developers → Webhooks → Signing secret).
# OBRIGATÓRIO para validar eventos recebidos em POST /billing/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=whsec_...
# Timeout (ms) das chamadas à API do Stripe.
STRIPE_REQUEST_TIMEOUT_MS=15000

# ===================================
# PUPPETEER (PDF generation) — opcional
# ===================================
# Caminho do binário do Chromium (default: bundled). Útil em ambientes restritos.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ===================================
# LOGGING / OBSERVABILIDADE
# ===================================
# Nível mínimo dos logs: error | warn | log | debug | verbose
LOG_LEVEL=log
# Output legível com cores em vez de JSON (default: true em dev, false em prod).
# Aceita 'true'/'false' — vazio = auto (true se NODE_ENV=development).
LOG_PRETTY=
# Retenção (em dias) das tabelas de log persistido. O cron diário às 04:00
# (America/Sao_Paulo) apaga linhas mais antigas que esses prazos.
LOG_RETENTION_NOTIFICATION_DAYS=90
LOG_RETENTION_AI_USAGE_DAYS=365
LOG_RETENTION_PII_DAYS=180
LOG_RETENTION_STALE_DAYS=60

# ===================================
# OPENTELEMETRY (tracing distribuído)
# ===================================
# Endpoint OTLP do coletor (Grafana Cloud Tempo, Jaeger, etc.).
# Se omitido: traces são descartados (NoopSpanProcessor).
# Formato Grafana Cloud: https://tempo-prod-XX-prod-XX.grafana.net/tempo/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# Credenciais do coletor (Grafana Cloud exige Basic auth em base64).
# Formato: Authorization=Basic <base64(instanceId:token)>
OTEL_EXPORTER_OTLP_HEADERS=
# Fração de traces amostrados: 1.0 = 100%, 0.1 = 10% (default prod).
OTEL_TRACES_SAMPLER_ARG=1.0
