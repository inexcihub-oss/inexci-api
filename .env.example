# ===================================
# DATABASE (PostgreSQL)
# ===================================
DATABASE_URL=postgresql://inexci_user:inexci_pass@localhost:5432/inexci

# ===================================
# JWT (Autenticação)
# ===================================
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION_TIME=7d

# ===================================
# APPLICATION
# ===================================
NODE_ENV=development
PORT=3000

# ===================================
# FRONTEND (URLs)
# ===================================
DASHBOARD_URL=http://localhost:3001

# ===================================
# SUPABASE (Storage)
# ===================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET_NAME=documents

# ===================================
# BREVO (E-mail transacional legado)
# ===================================
BREVO_API_KEY=your-brevo-api-key

# ===================================
# E-MAIL (SMTP — Fase 6)
# ===================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Inexci
MAIL_FROM_ADDRESS=noreply@inexci.com.br

# ===================================
# SUPABASE (Storage)
# ===================================
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_KEY=placeholder-key-for-local-tests
SUPABASE_BUCKET_NAME=documents

# ===================================
# REDIS (Filas — Fase 6)
# ===================================
REDIS_HOST=localhost
REDIS_PORT=6379
