{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "roots": ["<rootDir>"],
  "testEnvironment": "<rootDir>/e2e-test-environment.js",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(@faker-js)/)",
    "e2e-test-environment\\.js$"
  ],
  "testTimeout": 30000,
  "setupFiles": ["<rootDir>/env.setup.ts"],
  "forceExit": true
}
