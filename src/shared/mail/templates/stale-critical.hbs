{{#> _layout title="⚠️ Alerta — Solicitação Parada" preferencesUrl=preferencesUrl}}
  <div class='alert-critical'>
    <p style='margin: 0 !important;'>
      <strong>⚠️ Atenção!</strong>
      A solicitação abaixo está parada há <strong>{{staleDays}} dias</strong>.
    </p>
  </div>

  <div class='info-box'>
    <p><strong>Paciente:</strong> {{patientName}}</p>
    {{#if requestId}}<p><strong>Protocolo:</strong> #{{requestId}}</p>{{/if}}
    <p><strong>Status atual:</strong> {{currentStatus}}</p>
    {{#if lastMovedAt}}<p><strong>Última movimentação:</strong> {{lastMovedAt}}</p>{{/if}}
  </div>

  <p>
    Esta solicitação ultrapassou o prazo esperado de resolução.
    É necessária <strong>ação imediata</strong> para evitar prejuízos ao paciente.
  </p>

  {{#if dashboardUrl}}
    <p style='text-align: center; margin: 26px 0;'>
      <a class='btn' href='{{dashboardUrl}}'>Abrir Solicitação</a>
    </p>
  {{/if}}
{{/_layout}}
