<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
      body {
        font-family: 'Inter', Arial, Helvetica, sans-serif;
        background: #f5f5f5;
        margin: 0;
        padding: 0;
        -webkit-font-smoothing: antialiased;
      }
      .email-wrapper {
        width: 100%;
        background: #f5f5f5;
        padding: 40px 0;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }
      .email-header {
        background: #0f766e;
        padding: 28px 40px;
      }
      .email-header img {
        height: 32px;
        margin-bottom: 8px;
      }
      .email-header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 20px;
        font-weight: 700;
        line-height: 1.3;
      }
      .email-body {
        padding: 32px 40px;
        color: #374151;
        font-size: 15px;
        line-height: 1.6;
      }
      .email-body p {
        margin: 0 0 16px;
      }
      .email-body a {
        color: #0f766e;
      }
      .email-body .btn {
        display: inline-block;
        background: #0f766e;
        color: #ffffff;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 14px;
        margin-top: 8px;
      }
      .email-body .btn:hover {
        background: #0d6560;
      }
      .info-box {
        background: #f0fdfa;
        border-left: 4px solid #0f766e;
        border-radius: 4px;
        padding: 16px 20px;
        margin: 20px 0;
      }
      .info-box p {
        margin: 4px 0;
        font-size: 14px;
      }
      .info-box strong {
        color: #0f766e;
      }
      .status-change {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin: 24px 0;
        padding: 20px;
        background: #f0fdfa;
        border-radius: 8px;
        text-align: center;
        flex-wrap: wrap;
      }
      .status-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 6px;
        font-weight: 700;
        font-size: 14px;
      }
      .status-old {
        background: #e5e7eb;
        color: #6b7280;
      }
      .status-new {
        background: #0f766e;
        color: #ffffff;
      }
      .arrow {
        font-size: 20px;
        color: #9ca3af;
      }
      .alert-critical {
        background: #fef2f2;
        border-left: 4px solid #dc2626;
        border-radius: 4px;
        padding: 16px 20px;
        margin: 20px 0;
      }
      .alert-critical strong {
        color: #dc2626;
      }
      .email-footer {
        background: #f9fafb;
        padding: 20px 40px;
        text-align: center;
        font-size: 12px;
        color: #9ca3af;
        border-top: 1px solid #e5e7eb;
        line-height: 1.5;
      }
      .email-footer a {
        color: #0f766e;
        text-decoration: none;
      }
      @media only screen and (max-width: 640px) {
        .email-wrapper {
          padding: 16px 8px;
        }
        .email-header,
        .email-body,
        .email-footer {
          padding-left: 24px;
          padding-right: 24px;
        }
        .status-change {
          flex-direction: column;
          gap: 8px;
        }
      }
    </style>
  </head>
  <body>
    <div class='email-wrapper'>
      <div class='email-container'>
        <div class='email-header'>
          <h1>{{title}}</h1>
        </div>
        <div class='email-body'>
          {{> @partial-block}}
        </div>
        <div class='email-footer'>
          Inexci — Sistema de Gestão Cirúrgica<br />
          <a href='mailto:suporte@inexci.com.br'>suporte@inexci.com.br</a><br />
          <a href='{{preferencesUrl}}'>Gerenciar preferências de notificação</a>
        </div>
      </div>
    </div>
  </body>
</html>