<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
      * { box-sizing: border-box; }
      body {
        font-family: 'Inter', Arial, Helvetica, sans-serif;
        background-color: #eef2f3;
        margin: 0;
        padding: 0;
        -webkit-font-smoothing: antialiased;
      }
      img { border: 0; outline: none; text-decoration: none; display: block; }
      table { border-collapse: collapse; mso-table-lspace: 0; mso-table-rspace: 0; }
      .email-wrapper {
        width: 100%;
        background-color: #eef2f3;
        padding: 44px 0;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 6px 28px rgba(0, 0, 0, 0.09), 0 2px 6px rgba(0, 0, 0, 0.05);
      }
      .accent-bar {
        height: 3px;
        background: linear-gradient(90deg, #0f766e 0%, #2dd4bf 50%, #0f766e 100%);
        background-color: #0f766e;
      }
      .email-header {
        background-color: #0f766e;
        background: linear-gradient(145deg, #0d7065 0%, #134e4a 100%);
        padding: 30px 44px 28px;
      }
      .email-header img {
        height: 26px;
        margin-bottom: 16px;
      }
      .email-header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 20px;
        font-weight: 700;
        line-height: 1.3;
        letter-spacing: -0.3px;
      }
      .email-body {
        padding: 34px 44px;
        color: #374151;
        font-size: 15px;
        line-height: 1.7;
      }
      .email-body p { margin: 0 0 16px; color: #374151; }
      .email-body ul { margin: 0 0 16px; padding-left: 22px; }
      .email-body li { margin-bottom: 7px; color: #374151; line-height: 1.6; }
      .email-body a { color: #0f766e; text-decoration: none; font-weight: 500; }
      .btn {
        display: inline-block;
        background-color: #0f766e;
        background: linear-gradient(135deg, #0f766e, #0d9488);
        color: #ffffff !important;
        text-decoration: none !important;
        padding: 13px 30px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        letter-spacing: 0.2px;
      }
      .info-box {
        background-color: #f0fdfa;
        border-left: 3px solid #0f766e;
        border-radius: 8px;
        padding: 18px 20px;
        margin: 20px 0;
      }
      .info-box p { margin: 5px 0 !important; font-size: 14px !important; color: #374151 !important; }
      .info-box strong { color: #0f766e; font-weight: 600; }
      .status-table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 22px 0; }
      .status-table td {
        background-color: #f0fdfa;
        text-align: center;
        vertical-align: middle;
        padding: 18px 10px;
      }
      .status-table .td-first {
        border-radius: 8px 0 0 8px;
        padding-left: 18px;
      }
      .status-table .td-last {
        border-radius: 0 8px 8px 0;
        padding-right: 18px;
      }
      .status-badge {
        display: inline-block;
        padding: 7px 18px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.2px;
      }
      .status-old { background-color: #f3f4f6; color: #6b7280; border: 1px solid #e5e7eb; }
      .status-new { background-color: #0f766e; color: #ffffff; }
      .status-arrow { font-size: 18px; color: #9ca3af; }
      .alert-critical {
        background-color: #fff1f2;
        border-left: 3px solid #dc2626;
        border-radius: 8px;
        padding: 16px 20px;
        margin: 20px 0;
      }
      .alert-critical strong { color: #dc2626; }
      .alert-warning {
        background-color: #fffbeb;
        border-left: 3px solid #f59e0b;
        border-radius: 8px;
        padding: 16px 20px;
        margin: 20px 0;
      }
      .alert-warning strong { color: #92400e; }
      .text-box {
        background-color: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 14px 18px;
        font-size: 14px;
        color: #4b5563;
        white-space: pre-wrap;
        word-break: break-word;
        margin: 12px 0;
      }
      .value-display {
        text-align: center;
        font-size: 30px;
        font-weight: 700;
        color: #0f766e;
        letter-spacing: -0.5px;
        padding: 14px 0;
      }
      .divider { height: 1px; background-color: #f0f0f0; border: none; margin: 22px 0; }
      .email-footer {
        background-color: #f8fafb;
        padding: 22px 44px;
        text-align: center;
        border-top: 1px solid #e8eaed;
      }
      .email-footer p { font-size: 12px; color: #9ca3af; margin: 0 0 4px; line-height: 1.5; }
      .email-footer a { color: #0f766e; text-decoration: none; font-size: 12px; }
      @media only screen and (max-width: 640px) {
        .email-wrapper { padding: 16px 0; }
        .email-header, .email-body, .email-footer {
          padding-left: 24px !important;
          padding-right: 24px !important;
        }
        .email-header h1 { font-size: 18px; }
      }
    </style>
  </head>
  <body>
    <div class='email-wrapper'>
      <div class='email-container'>
        <div class='accent-bar'></div>
        <div class='email-header'>
          {{#if logoUrl}}<img src='{{logoUrl}}' alt='Inexci' />{{/if}}
          <h1>{{title}}</h1>
        </div>
        <div class='email-body'>
          {{> @partial-block}}
        </div>
        <div class='email-footer'>
          <p><strong style='color: #6b7280; font-weight: 600;'>Inexci</strong> — Sistema de Gestão Cirúrgica</p>
          <p><a href='mailto:suporte@inexci.com.br'>suporte@inexci.com.br</a></p>
          {{#if preferencesUrl}}<p style='margin-top: 8px;'><a href='{{preferencesUrl}}'>Gerenciar preferências de notificação</a></p>{{/if}}
        </div>
      </div>
    </div>
  </body>
</html>
