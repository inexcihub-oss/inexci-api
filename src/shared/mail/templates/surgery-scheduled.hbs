{{#> _layout title="Cirurgia Agendada"}}
  <p>A cirurgia do paciente <strong>{{patientName}}</strong> foi agendada com sucesso.</p>

  <p class='value-display'>{{surgeryDate}}</p>

  <div class='info-box'>
    <p><strong>Hospital:</strong> {{hospitalName}}</p>
    <p><strong>Protocolo:</strong> #{{requestId}}</p>
  </div>

  <p>
    Certifique-se de que todos os documentos e materiais necessários estejam
    separados e prontos com antecedência.
  </p>

  <p style='font-size: 13px; color: #6b7280; margin-top: 20px;'>
    Em caso de necessidade de reagendamento ou dúvidas, acesse a plataforma Inexci.
  </p>
{{/_layout}}
