{{#> _layout title="Fatura Enviada ao Convênio"}}
  <p>
    A fatura referente à cirurgia do paciente <strong>{{patientName}}</strong>
    foi enviada ao convênio com sucesso.
  </p>

  <p class='value-display'>{{invoiceValue}}</p>

  <div class='info-box'>
    <p><strong>Protocolo da Fatura:</strong> {{invoiceProtocol}}</p>
    <p><strong>Solicitação:</strong> #{{requestId}}</p>
    {{#if paymentDeadline}}
      <p><strong>Prazo de Pagamento:</strong> {{paymentDeadline}}</p>
    {{/if}}
  </div>

  <p>Aguardando a confirmação do pagamento pelo convênio.</p>

  <p style='font-size: 13px; color: #6b7280; margin-top: 20px;'>
    Acompanhe o status do pagamento diretamente na plataforma Inexci.
  </p>
{{/_layout}}
