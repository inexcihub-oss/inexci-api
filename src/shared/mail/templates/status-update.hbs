{{#> _layout title="Atualização de Status da Solicitação"}}
  <p>Olá, <strong>{{patientName}}</strong>!</p>
  <p>O status da sua solicitação cirúrgica foi atualizado.</p>

  <table class='status-table'>
    <tr>
      <td class='td-first'><span class='status-badge status-old'>{{oldStatus}}</span></td>
      <td><span class='status-arrow'>→</span></td>
      <td class='td-last'><span class='status-badge status-new'>{{newStatus}}</span></td>
    </tr>
  </table>

  <div class='info-box'>
    <p><strong>Protocolo:</strong> #{{requestId}}</p>
    <p><strong>Data da alteração:</strong> {{changedAt}}</p>
  </div>

  <p>Caso tenha dúvidas, entre em contato com seu médico ou a equipe responsável.</p>
{{/_layout}}
