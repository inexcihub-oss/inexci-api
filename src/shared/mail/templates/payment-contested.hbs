{{#> _layout title="Contestação de Pagamento"}}
  <p>Prezado Convênio,</p>
  <p>
    Verificamos uma divergência no pagamento referente à cirurgia do paciente
    <strong>{{patientName}}</strong>.
  </p>

  <table style='width: 100%; border-collapse: separate; border-spacing: 0; margin: 22px 0;'>
    <tr>
      <td style='width: 50%; padding-right: 6px; vertical-align: top;'>
        <div style='background-color: #f0fdfa; border: 1px solid #ccfbf1; border-radius: 10px; padding: 18px 16px; text-align: center;'>
          <div style='font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; font-weight: 500;'>Valor Faturado</div>
          <div style='font-size: 22px; font-weight: 700; color: #0f766e; letter-spacing: -0.3px;'>{{invoiceValue}}</div>
        </div>
      </td>
      <td style='width: 50%; padding-left: 6px; vertical-align: top;'>
        <div style='background-color: #fff1f2; border: 1px solid #fecdd3; border-radius: 10px; padding: 18px 16px; text-align: center;'>
          <div style='font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; font-weight: 500;'>Valor Recebido</div>
          <div style='font-size: 22px; font-weight: 700; color: #dc2626; letter-spacing: -0.3px;'>{{receivedValue}}</div>
        </div>
      </td>
    </tr>
  </table>

  <div class='info-box'>
    <p><strong>Protocolo:</strong> #{{requestId}}</p>
  </div>

  <p><strong>Justificativa da contestação:</strong></p>
  <div class='text-box'>{{message}}</div>

  <p>
    Solicitamos a análise e regularização do valor conforme a fatura emitida.
    Aguardamos retorno no prazo habitual.
  </p>

  <p style='font-size: 13px; color: #6b7280; margin-top: 20px;'>
    Para esclarecimentos, entre em contato pelo e-mail
    <a href='mailto:suporte@inexci.com.br'>suporte@inexci.com.br</a>.
  </p>
{{/_layout}}
