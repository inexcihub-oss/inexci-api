{{#> _layout title="Atualização da sua Solicitação Cirúrgica" preferencesUrl=preferencesUrl}}
  <p>Olá, <strong>{{patientName}}</strong>!</p>
  <p>O status da sua solicitação cirúrgica foi atualizado.</p>

  <div class='status-change'>
    <span class='status-badge status-old'>{{oldStatus}}</span>
    <span class='arrow'>→</span>
    <span class='status-badge status-new'>{{newStatus}}</span>
  </div>

  <div class='info-box'>
    <p><strong>Solicitação:</strong> {{requestId}}</p>
    <p><strong>Data da alteração:</strong> {{changedAt}}</p>
  </div>

  <p>Caso tenha dúvidas, entre em contato com seu médico ou a equipe responsável.</p>
{{/_layout}}
