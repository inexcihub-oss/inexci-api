{{#> _layout title="Status da Solicitação Atualizado"}}
  <p>O status de uma solicitação cirúrgica foi atualizado.</p>

  <table class='status-table'>
    <tr>
      <td class='td-first'><span class='status-badge status-old'>{{oldStatus}}</span></td>
      <td><span class='status-arrow'>→</span></td>
      <td class='td-last'><span class='status-badge status-new'>{{newStatus}}</span></td>
    </tr>
  </table>

  <div class='info-box'>
    <p><strong>Paciente:</strong> {{patientName}}</p>
    <p><strong>Alterado por:</strong> {{changedBy}}</p>
    <p><strong>Data:</strong> {{changedAt}}</p>
  </div>

  {{#if dashboardUrl}}
    <p style='text-align: center; margin: 26px 0;'>
      <a class='btn' href='{{dashboardUrl}}'>Ver Solicitação</a>
    </p>
  {{/if}}
{{/_layout}}
