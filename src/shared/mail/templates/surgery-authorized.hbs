{{#> _layout title="Autorização Recebida"}}
  <p>A autorização do convênio foi recebida para o paciente <strong>{{patientName}}</strong>.</p>

  <div class='info-box'>
    <p><strong>Protocolo:</strong> #{{requestId}}</p>
  </div>

  {{#if authorizedProcedures.length}}
    <p><strong>Procedimentos autorizados:</strong></p>
    <ul>
      {{#each authorizedProcedures}}
        <li>{{this}}</li>
      {{/each}}
    </ul>
  {{/if}}

  <p>O agendamento da cirurgia já pode ser realizado pela plataforma Inexci.</p>

  <p style='font-size: 13px; color: #6b7280; margin-top: 20px;'>
    Acesse a plataforma para acompanhar os próximos passos e realizar o agendamento.
  </p>
{{/_layout}}
