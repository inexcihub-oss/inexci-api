<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <title>Laudo Médico</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', Arial, sans-serif;
        font-size: 12px;
        color: #111111;
        background: #ffffff;
      }

      /* ── Header ─────────────────────────────────────── */
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: 1px;
        margin-bottom: 16px;
      }

      .report-title {
        font-size: 20px;
        font-weight: 300;
        letter-spacing: -0.02em;
        color: #000000;
        line-height: 1.3;
      }

      .report-date {
        font-size: 12px;
        color: #737373;
        line-height: 1.17;
        white-space: nowrap;
      }

      /* ── Section ─────────────────────────────────────── */
      .section {
        margin-bottom: 16px;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .section-heading {
        border-bottom: 1px solid #e5e5e5;
        padding-bottom: 8px;
        margin-bottom: 10px;
      }

      .section-title {
        font-size: 14px;
        font-weight: 600;
        color: #171717;
        line-height: 1.14;
      }

      /* ── Patient grid ─────────────────────────────────── */
      .patient-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        row-gap: 5px;
        column-gap: 16px;
      }

      .patient-row {
        display: flex;
        align-items: baseline;
        gap: 4px;
      }

      .patient-label {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        white-space: nowrap;
      }

      .patient-value {
        font-size: 12px;
        font-weight: 400;
        color: #111111;
      }

      /* ── Body text ────────────────────────────────────── */
      .body-text {
        font-size: 12px;
        line-height: 1.333;
        color: #111111;
        white-space: pre-line;
      }

      /* ── Images grid ──────────────────────────────────── */
      .images-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
      }

      .image-item {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .exam-image {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
        display: block;
      }

      /* ── Signature ────────────────────────────────────── */
      .signature-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 160px;
        margin-left: auto;
        margin-top: 40px;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .signature-img {
        width: 130px;
        height: auto;
        margin-bottom: 4px;
      }

      .signature-line {
        width: 100%;
        border: none;
        border-top: 1px solid #000000;
        margin-bottom: 6px;
      }

      .signature-name {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        text-align: center;
      }

      .signature-specialty {
        font-size: 10px;
        font-weight: 400;
        color: #111111;
        text-align: center;
        line-height: 1.2;
        max-width: 160px;
        margin-top: 2px;
      }

      .signature-crm {
        font-size: 10px;
        font-weight: 400;
        color: #111111;
        text-align: left;
        margin-top: 2px;
      }
    </style>
  </head>
  <body>

    <!-- ── Header ────────────────────────────────────────── -->
    <div class='page-header'>
      <h1 class='report-title'>LAUDO MÉDICO</h1>
      <span class='report-date'>Data: {{today}}</span>
    </div>

    <!-- ── Dados do Paciente ──────────────────────────────── -->
    <div class='section'>
      <div class='section-heading'>
        <span class='section-title'>Dados do paciente</span>
      </div>
      <div class='patient-grid'>
        {{#if patientName}}
          <div class='patient-row'>
            <span class='patient-label'>Nome:</span>
            <span class='patient-value'>{{patientName}}</span>
          </div>
        {{/if}}
        {{#if patientBirthDate}}
          <div class='patient-row'>
            <span class='patient-label'>Data de Nascimento:</span>
            <span class='patient-value'>{{patientBirthDate}}</span>
          </div>
        {{/if}}
        {{#if patientRg}}
          <div class='patient-row'>
            <span class='patient-label'>RG:</span>
            <span class='patient-value'>{{patientRg}}</span>
          </div>
        {{/if}}
        {{#if patientCpf}}
          <div class='patient-row'>
            <span class='patient-label'>CPF:</span>
            <span class='patient-value'>{{patientCpf}}</span>
          </div>
        {{/if}}
        {{#if patientAddress}}
          <div class='patient-row'>
            <span class='patient-label'>Endereço:</span>
            <span class='patient-value'>{{patientAddress}}</span>
          </div>
        {{/if}}
        {{#if patientZipCode}}
          <div class='patient-row'>
            <span class='patient-label'>CEP:</span>
            <span class='patient-value'>{{patientZipCode}}</span>
          </div>
        {{/if}}
        {{#if patientPhone}}
          <div class='patient-row'>
            <span class='patient-label'>Telefone:</span>
            <span class='patient-value'>{{patientPhone}}</span>
          </div>
        {{/if}}
        {{#if patientHealthPlan}}
          <div class='patient-row'>
            <span class='patient-label'>Convênio:</span>
            <span class='patient-value'>{{patientHealthPlan}}</span>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- ── Histórico e Diagnóstico ────────────────────────── -->
    {{#if historyAndDiagnosis}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Histórico e diagnóstico</span>
        </div>
        <p class='body-text'>{{historyAndDiagnosis}}</p>
      </div>
    {{/if}}

    <!-- ── Imagens do Exame ────────────────────────────────── -->
    {{#if examImages}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Imagens do exame</span>
        </div>
        <div class='images-grid'>
          {{#each examImages}}
            <div class='image-item'>
              <img class='exam-image' src='{{this}}' alt='Imagem do exame' />
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- ── Conduta ─────────────────────────────────────────── -->
    {{#if conduct}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Conduta</span>
        </div>
        <p class='body-text'>{{conduct}}</p>
      </div>
    {{/if}}

  </body>
</html>