<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <title>Contestação à Negativa de Autorização Cirúrgica</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', Arial, sans-serif;
        font-size: 12px;
        color: #111111;
        background: #ffffff;
      }

      /* ── Header ─────────────────────────────────────── */
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding-bottom: 1px;
        margin-bottom: 16px;
      }

      .report-title {
        font-size: 20px;
        font-weight: 300;
        letter-spacing: -0.02em;
        color: #000000;
        line-height: 1.3;
        max-width: 340px;
      }

      .report-date {
        font-size: 12px;
        color: #737373;
        line-height: 1.17;
        white-space: nowrap;
        padding-top: 4px;
      }

      /* ── Section ─────────────────────────────────────── */
      .section {
        margin-bottom: 16px;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .section-heading {
        border-bottom: 1px solid #e5e5e5;
        padding-bottom: 8px;
        margin-bottom: 10.5px;
      }

      .section-title {
        font-size: 14px;
        font-weight: 600;
        color: #171717;
        line-height: 1.14;
      }

      /* ── Patient grid ─────────────────────────────────── */
      .patient-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        row-gap: 5px;
        column-gap: 16px;
      }

      .patient-row {
        display: flex;
        align-items: baseline;
        gap: 4px;
      }

      .patient-label {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        white-space: nowrap;
      }

      .patient-value {
        font-size: 12px;
        font-weight: 400;
        color: #111111;
      }

      /* ── Contestation body text ───────────────────────── */
      .body-text {
        font-size: 12px;
        line-height: 1.333;
        color: #111111;
        white-space: pre-line;
      }

      /* ── Table ────────────────────────────────────────── */
      .data-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid #dcdfe3;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .data-table th {
        font-family: 'Inter', Arial, sans-serif;
        font-size: 12px;
        font-weight: 500;
        color: #111111;
        text-align: left;
        padding: 4px 10px;
        line-height: 1.333;
        border-right: 1px solid #dcdfe3;
        border-bottom: 1px solid #dcdfe3;
        background: #ffffff;
      }

      .data-table th:last-child {
        border-right: none;
      }

      .data-table td {
        font-family: 'Inter', Arial, sans-serif;
        font-size: 12px;
        font-weight: 400;
        color: #111111;
        text-align: left;
        padding: 8px 10px;
        line-height: 1.333;
        border-right: 1px solid #dcdfe3;
        border-bottom: 1px solid #dcdfe3;
        vertical-align: top;
      }

      .data-table td:last-child {
        border-right: none;
      }

      .data-table tr:last-child td {
        border-bottom: none;
      }

      .data-table tr:nth-child(odd) td {
        background: #f2f2f2;
      }

      .data-table tr:nth-child(even) td {
        background: #ffffff;
      }

      /* Procedures table: 4 columns with specific widths */
      .col-procedure {
        width: 27.78%;
      }
      .col-tuss {
        width: 27.78%;
      }
      .col-qty-req {
        width: 22.22%;
      }
      .col-qty-auth {
        width: 22.22%;
      }

      /* Materials table: 3 columns with specific widths */
      .col-material {
        width: 48.38%;
      }
      .col-mat-req {
        width: 25.81%;
      }
      .col-mat-auth {
        width: 25.81%;
      }

      /* ── Attachments grid ─────────────────────────────── */
      .attachments-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
      }

      .attachment-item {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .attachment-img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
        display: block;
      }

      .attachment-placeholder {
        width: 100%;
        aspect-ratio: 1 / 1;
        border: 1px dashed #dcdfe3;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.8);
        background-image: linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.8),
          #f2f2f2
        );
      }

      .attachment-icon {
        width: 38px;
        height: 38px;
        opacity: 0.35;
      }

      /* ── Signature ────────────────────────────────────── */
      .signature-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 150px;
        margin-left: auto;
        margin-top: 24px;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .signature-img {
        width: 130px;
        height: auto;
        margin-bottom: 4px;
      }

      .signature-line {
        width: 100%;
        border: none;
        border-top: 1px solid #000000;
        margin-bottom: 6px;
      }

      .signature-name {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        text-align: center;
        line-height: 1;
      }

      .signature-specialty {
        font-size: 10px;
        font-weight: 400;
        color: #111111;
        text-align: center;
        line-height: 1.2;
        max-width: 150px;
        margin-top: 2px;
      }

      .signature-crm {
        font-size: 10px;
        font-weight: 400;
        color: #111111;
        text-align: left;
        margin-top: 2px;
      }
    </style>
  </head>
  <body>

    <!-- ── Header ───────────────────────────────────────── -->
    <div class='page-header'>
      <h1 class='report-title'>CONTESTAÇÃO À NEGATIVA DE AUTORIZAÇÃO CIRÚRGICA</h1>
      <span class='report-date'>Data: {{today}}</span>
    </div>

    <!-- ── Dados do paciente ─────────────────────────────── -->
    <div class='section'>
      <div class='section-heading'>
        <span class='section-title'>Dados do paciente</span>
      </div>
      <div class='patient-grid'>
        {{#if patientName}}
          <div class='patient-row'>
            <span class='patient-label'>Nome:</span>
            <span class='patient-value'>{{patientName}}</span>
          </div>
        {{/if}}
        {{#if patientBirthDate}}
          <div class='patient-row'>
            <span class='patient-label'>Data de Nascimento:</span>
            <span class='patient-value'>{{patientBirthDate}}</span>
          </div>
        {{/if}}
        {{#if patientRg}}
          <div class='patient-row'>
            <span class='patient-label'>RG:</span>
            <span class='patient-value'>{{patientRg}}</span>
          </div>
        {{/if}}
        {{#if patientCpf}}
          <div class='patient-row'>
            <span class='patient-label'>CPF:</span>
            <span class='patient-value'>{{patientCpf}}</span>
          </div>
        {{/if}}
        {{#if patientAddress}}
          <div class='patient-row'>
            <span class='patient-label'>Endereço:</span>
            <span class='patient-value'>{{patientAddress}}</span>
          </div>
        {{/if}}
        {{#if patientZipCode}}
          <div class='patient-row'>
            <span class='patient-label'>CEP:</span>
            <span class='patient-value'>{{patientZipCode}}</span>
          </div>
        {{/if}}
        {{#if patientPhone}}
          <div class='patient-row'>
            <span class='patient-label'>Telefone:</span>
            <span class='patient-value'>{{patientPhone}}</span>
          </div>
        {{/if}}
        {{#if patientHealthPlan}}
          <div class='patient-row'>
            <span class='patient-label'>Convênio:</span>
            <span class='patient-value'>{{patientHealthPlan}}</span>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- ── Contestação ───────────────────────────────────── -->
    <div class='section'>
      <div class='section-heading'>
        <span class='section-title'>Contestação</span>
      </div>
      <p class='body-text'>{{reason}}</p>
    </div>

    <!-- ── Procedimento solicitado ───────────────────────── -->
    {{#if procedures}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Procedimento solicitado</span>
        </div>
        <table class='data-table'>
          <colgroup>
            <col class='col-procedure' />
            <col class='col-tuss' />
            <col class='col-qty-req' />
            <col class='col-qty-auth' />
          </colgroup>
          <thead>
            <tr>
              <th>Procedimentos</th>
              <th>TUSS</th>
              <th>Qntd. Solicitada</th>
              <th>Qntd. Autorizada</th>
            </tr>
          </thead>
          <tbody>
            {{#each procedures}}
              <tr>
                <td>{{this.description}}</td>
                <td>{{this.tussCode}}</td>
                <td>{{this.requestedQuantity}}</td>
                <td>{{#if
                    (isDefined this.authorizedQuantity)
                  }}{{this.authorizedQuantity}}{{else}}—{{/if}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    <!-- ── Material solicitado ───────────────────────────── -->
    {{#if opmeItems}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Material solicitado</span>
        </div>
        <table class='data-table'>
          <colgroup>
            <col class='col-material' />
            <col class='col-mat-req' />
            <col class='col-mat-auth' />
          </colgroup>
          <thead>
            <tr>
              <th>Material</th>
              <th>Qntd. Solicitada</th>
              <th>Qntd. Autorizada</th>
            </tr>
          </thead>
          <tbody>
            {{#each opmeItems}}
              <tr>
                <td>{{this.name}}</td>
                <td>{{this.requestedQuantity}}</td>
                <td>{{#if
                    (isDefined this.authorizedQuantity)
                  }}{{this.authorizedQuantity}}{{else}}—{{/if}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    <!-- ── Anexos ────────────────────────────────────────── -->
    {{#if attachments}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Anexos</span>
        </div>
        <div class='attachments-grid'>
          {{#each attachments}}
            <div class='attachment-item'>
              <img
                class='attachment-img'
                src='{{this}}'
                alt='Anexo {{@index}}'
              />
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- ── Assinatura ────────────────────────────────────── -->
    <div class='signature-block'>
      {{#if doctorSignatureUrl}}
        <img
          class='signature-img'
          src='{{doctorSignatureUrl}}'
          alt='Assinatura'
        />
      {{/if}}
      <hr class='signature-line' />
      <span class='signature-name'>{{doctorName}}</span>
      {{#if doctorSpecialty}}
        <span class='signature-specialty'>{{doctorSpecialty}}</span>
      {{/if}}
      {{#if doctorCrm}}
        <span class='signature-crm'>{{doctorCrm}}</span>
      {{/if}}
    </div>

  </body>
</html>