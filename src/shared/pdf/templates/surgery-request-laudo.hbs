<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <title>Solicitação Cirúrgica</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', Arial, sans-serif;
        font-size: 12px;
        color: #111111;
        background: #ffffff;
        padding-bottom: 90px;
      }

      /* ── Header ─────────────────────────────────────── */
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: 1px;
        margin-bottom: 16px;
      }

      .report-title {
        font-size: 20px;
        font-weight: 300;
        letter-spacing: -0.02em;
        color: #000000;
        line-height: 1.3;
      }

      .report-date {
        font-size: 12px;
        color: #737373;
        line-height: 1.17;
        white-space: nowrap;
      }

      /* ── Section ─────────────────────────────────────── */
      .section {
        margin-bottom: 16px;
      }

      .section-heading {
        border-bottom: 1px solid #e5e5e5;
        padding-bottom: 8px;
        margin-bottom: 10px;
      }

      .section-title {
        font-size: 14px;
        font-weight: 600;
        color: #171717;
        line-height: 1.14;
      }

      /* ── Patient grid ─────────────────────────────────── */
      .patient-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        row-gap: 5px;
        column-gap: 16px;
      }

      .patient-row {
        display: flex;
        align-items: baseline;
        gap: 4px;
      }

      .patient-label {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        white-space: nowrap;
      }

      .patient-value {
        font-size: 12px;
        font-weight: 400;
        color: #111111;
      }

      /* ── Body text ────────────────────────────────────── */
      .body-text {
        font-size: 12px;
        line-height: 1.333;
        color: #111111;
        white-space: pre-line;
      }

      /* ── Images grid ──────────────────────────────────── */
      .images-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        margin-bottom: 8px;
      }

      .exam-image {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border: 1px dashed #dcdfe3;
        border-radius: 4px;
        display: block;
      }

      /* ── Tables ───────────────────────────────────────── */
      .data-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid #dcdfe3;
        font-size: 12px;
        color: #111111;
      }

      .data-table th {
        font-weight: 500;
        text-align: left;
        padding: 6px 10px;
        border-bottom: 1px solid #dcdfe3;
        background: #ffffff;
      }

      .data-table td {
        padding: 8px 10px;
        border-bottom: 1px solid #dcdfe3;
        line-height: 1.333;
      }

      .data-table tr:last-child td {
        border-bottom: none;
      }

      .data-table tbody tr:nth-child(odd) td {
        background: #f2f2f2;
      }

      .data-table tbody tr:nth-child(even) td {
        background: #ffffff;
      }

      .col-right {
        border-right: 1px solid #dcdfe3;
      }

      /* ── Separator ────────────────────────────────────── */
      .separator {
        border: none;
        border-top: 1px solid #dcdfe3;
        margin: 12px 0;
      }

      /* ── Closing text ─────────────────────────────────── */
      .closing-text {
        font-size: 12px;
        color: #000000;
        line-height: 1.333;
        margin-bottom: 16px;
      }

      .text-bold {
        font-weight: 600;
      }

      /* ── Signature ────────────────────────────────────── */
      .signature-wrap {
        display: flex;
        align-items: flex-end;
        gap: 32px;
        margin-top: 32px;
      }

      .sig-left {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        min-width: 225px;
      }

      .sig-line {
        width: 100%;
        border: none;
        border-top: 1px solid #dcdfe3;
      }

      .sig-name {
        font-size: 12px;
        color: #000000;
        line-height: 1.333;
        text-align: center;
      }

      .sig-contact {
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding-bottom: 2px;
      }

      .sig-contact-text {
        font-size: 10px;
        color: #111111;
        line-height: 1.2;
      }

      .sig-info {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
      }

      .sig-doctor-name {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        line-height: 1;
      }

      .sig-specialty {
        font-size: 10px;
        color: #111111;
        line-height: 1.2;
        text-align: center;
        max-width: 150px;
      }

      .sig-crm {
        font-size: 10px;
        color: #111111;
        line-height: 1.2;
      }

      /* ── Signature image (above line) ─────────────────────────── */
      .sig-image {
        max-width: 120px;
        max-height: 60px;
        object-fit: contain;
        display: block;
        margin-bottom: 4px;
      }

      /* ── Page footer signature (fixed, bottom-right, all pages) ─ */
      .page-footer-sig {
        position: fixed;
        bottom: 16px;
        right: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        text-align: center;
      }

      .page-footer-sig-img {
        max-width: 80px;
        max-height: 40px;
        object-fit: contain;
        display: block;
        margin-bottom: 2px;
      }

      .page-footer-sig-name {
        font-size: 9px;
        font-weight: 600;
        color: #111111;
        line-height: 1.2;
      }

      .page-footer-sig-specialty {
        font-size: 8px;
        color: #111111;
        line-height: 1.2;
        max-width: 130px;
      }

      .page-footer-sig-crm {
        font-size: 8px;
        color: #111111;
        line-height: 1.2;
      }
    </style>
  </head>
  <body>

    <!-- ── Header ────────────────────────────────────────── -->
    <div class='page-header'>
      <h1 class='report-title'>LAUDO MÉDICO</h1>
      <span class='report-date'>Data: {{today}}</span>
    </div>

    <!-- ── Dados do Paciente ──────────────────────────────── -->
    <div class='section'>
      <div class='section-heading'>
        <span class='section-title'>Dados do paciente</span>
      </div>
      <div class='patient-grid'>
        {{#if patientName}}
          <div class='patient-row'>
            <span class='patient-label'>Nome:</span>
            <span class='patient-value'>{{patientName}}</span>
          </div>
        {{/if}}
        {{#if patientBirthDate}}
          <div class='patient-row'>
            <span class='patient-label'>Data de Nascimento:</span>
            <span class='patient-value'>{{patientBirthDate}}</span>
          </div>
        {{/if}}
        {{#if patientRg}}
          <div class='patient-row'>
            <span class='patient-label'>RG:</span>
            <span class='patient-value'>{{patientRg}}</span>
          </div>
        {{/if}}
        {{#if patientCpf}}
          <div class='patient-row'>
            <span class='patient-label'>CPF:</span>
            <span class='patient-value'>{{patientCpf}}</span>
          </div>
        {{/if}}
        {{#if patientAddress}}
          <div class='patient-row'>
            <span class='patient-label'>Endereço:</span>
            <span class='patient-value'>{{patientAddress}}</span>
          </div>
        {{/if}}
        {{#if patientZipCode}}
          <div class='patient-row'>
            <span class='patient-label'>CEP:</span>
            <span class='patient-value'>{{patientZipCode}}</span>
          </div>
        {{/if}}
        {{#if patientPhone}}
          <div class='patient-row'>
            <span class='patient-label'>Telefone:</span>
            <span class='patient-value'>{{patientPhone}}</span>
          </div>
        {{/if}}
        {{#if patientHealthPlan}}
          <div class='patient-row'>
            <span class='patient-label'>Convênio:</span>
            <span class='patient-value'>{{patientHealthPlan}}</span>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- ── Histórico e Diagnóstico ────────────────────────── -->
    {{#if historyAndDiagnosis}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Histórico e diagnóstico</span>
        </div>
        <p class='body-text'>{{historyAndDiagnosis}}</p>
      </div>
    {{/if}}

    <!-- ── Imagens de Exame ────────────────────────────────── -->
    {{#if examImages}}
      <div class='section'>
        <div class='images-grid'>
          {{#each examImages}}
            <img class='exam-image' src='{{this}}' alt='Imagem do exame' />
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- ── Conduta ─────────────────────────────────────────── -->
    {{#if conduct}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Conduta</span>
        </div>
        <p class='body-text'>{{conduct}}</p>
      </div>
    {{/if}}

    <!-- ── Procedimentos Solicitados (TUSS) ───────────────── -->
    {{#if procedures.length}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Procedimento solicitado</span>
        </div>
        <table class='data-table'>
          <thead>
            <tr>
              <th style='width:55%' class='col-right'>Procedimentos</th>
              <th style='width:30%' class='col-right'>TUSS</th>
              <th style='width:15%'>Quantidade</th>
            </tr>
          </thead>
          <tbody>
            {{#each procedures}}
              <tr>
                <td class='col-right'>{{name}}</td>
                <td class='col-right'>{{tussCode}}</td>
                <td>{{quantity}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    <!-- ── Material Solicitado (OPME) ────────────────────── -->
    {{#if opmeItems.length}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Material solicitado</span>
        </div>
        <table class='data-table'>
          <thead>
            <tr>
              <th style='width:80%' class='col-right'>Material</th>
              <th style='width:20%'>Quantidade</th>
            </tr>
          </thead>
          <tbody>
            {{#each opmeItems}}
              <tr>
                <td class='col-right'>{{name}}</td>
                <td>{{quantity}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    <!-- ── Fabricantes e Fornecedores ─────────────────────── -->
    {{#if fabricantesText}}
      <p class='closing-text'>
        <span class='text-bold'>Fabricantes:</span>
        {{fabricantesText}}
      </p>
    {{/if}}
    {{#if fornecedoresText}}
      <p class='closing-text'>
        <span class='text-bold'>Fornecedores:</span>
        {{fornecedoresText}}
      </p>
    {{/if}}

    {{#if hasSeparator}}
      <hr class='separator' />
    {{/if}}

    <!-- ── Local ──────────────────────────────────────────── -->
    {{#if localText}}
      <p class='closing-text'>
        <span class='text-bold'>Local:</span>
        {{localText}}
      </p>
    {{/if}}

    <!-- ── Encerramento ────────────────────────────────────── -->
    <p class='closing-text'>Colocando-me a disposição para maiores informações,</p>

    <!-- ── Assinatura ─────────────────────────────────────── -->
    <div class='signature-wrap'>
      <!-- Imagem + Linha + nome do médico -->
      <div class='sig-left'>
        {{#if doctorSignatureUrl}}
          <img
            class='sig-image'
            src='{{doctorSignatureUrl}}'
            alt='Assinatura do médico'
          />
        {{/if}}
        <hr class='sig-line' />
        <span class='sig-name'>{{doctorName}}</span>
      </div>

      <!-- E-mail e telefone -->
      {{#if hasDoctorContact}}
        <div class='sig-contact'>
          {{#if doctorEmail}}
            <span class='sig-contact-text'>
              <span class='text-bold'>E-mail:</span>
              {{doctorEmail}}
            </span>
          {{/if}}
          {{#if doctorPhone}}
            <span class='sig-contact-text'>
              <span class='text-bold'>Tel:</span>
              {{doctorPhone}}
            </span>
          {{/if}}
        </div>
      {{/if}}

      <!-- Dados do médico (nome em destaque + especialidade + CRM) -->
      {{#if hasDoctorInfo}}
        <div class='sig-info'>
          {{#if doctorName}}
            <span class='sig-doctor-name'>{{doctorName}}</span>
          {{/if}}
          {{#if doctorSpecialty}}
            <span class='sig-specialty'>{{doctorSpecialty}}</span>
          {{/if}}
          {{#if doctorCrm}}
            <span class='sig-crm'>{{doctorCrm}}</span>
          {{/if}}
        </div>
      {{/if}}
    </div>

    <!-- ── Rodapé fixo com assinatura (aparece em todas as páginas) ─ -->
    {{#if doctorSignatureUrl}}
      <div class='page-footer-sig'>
        <img
          class='page-footer-sig-img'
          src='{{doctorSignatureUrl}}'
          alt='Assinatura'
        />
        {{#if doctorName}}
          <span class='page-footer-sig-name'>{{doctorName}}</span>
        {{/if}}
        {{#if doctorSpecialty}}
          <span class='page-footer-sig-specialty'>{{doctorSpecialty}}</span>
        {{/if}}
        {{#if doctorCrm}}
          <span class='page-footer-sig-crm'>{{doctorCrm}}</span>
        {{/if}}
      </div>
    {{/if}}

  </body>
</html>