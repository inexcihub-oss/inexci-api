<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <title>Solicitação Cirúrgica</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', Arial, sans-serif;
        font-size: 12px;
        color: #111111;
        background: #ffffff;
        padding-bottom: 90px;
      }

      /* ── Header ─────────────────────────────────────── */
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: 1px;
        margin-bottom: 16px;
      }

      .report-title {
        font-size: 20px;
        font-weight: 300;
        letter-spacing: -0.02em;
        color: #000000;
        line-height: 1.3;
      }

      .report-date {
        font-size: 12px;
        color: #737373;
        line-height: 1.17;
        white-space: nowrap;
      }

      /* ── Section ─────────────────────────────────────── */
      .section {
        margin-bottom: 16px;
      }

      .section-heading {
        border-bottom: 1px solid #e5e5e5;
        padding-bottom: 8px;
        margin-bottom: 10px;
      }

      .section-title {
        font-size: 14px;
        font-weight: 600;
        color: #171717;
        line-height: 1.14;
      }

      /* ── Patient grid ─────────────────────────────────── */
      .patient-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        row-gap: 5px;
        column-gap: 16px;
      }

      .patient-row {
        display: flex;
        align-items: baseline;
        gap: 4px;
      }

      .patient-label {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        white-space: nowrap;
      }

      .patient-value {
        font-size: 12px;
        font-weight: 400;
        color: #111111;
      }

      /* ── Body text ────────────────────────────────────── */
      .body-text {
        font-size: 12px;
        line-height: 1.333;
        color: #111111;
        white-space: pre-line;
      }

      /* ── Images grid ──────────────────────────────────── */
      .images-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        margin-bottom: 8px;
      }

      .exam-image {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border: 1px dashed #dcdfe3;
        border-radius: 4px;
        display: block;
      }

      /* ── Tables ───────────────────────────────────────── */
      .data-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid #dcdfe3;
        font-size: 12px;
        color: #111111;
      }

      .data-table th {
        font-weight: 500;
        text-align: left;
        padding: 6px 10px;
        border-bottom: 1px solid #dcdfe3;
        background: #ffffff;
      }

      .data-table td {
        padding: 8px 10px;
        border-bottom: 1px solid #dcdfe3;
        line-height: 1.333;
      }

      .data-table tr:last-child td {
        border-bottom: none;
      }

      .data-table tbody tr:nth-child(odd) td {
        background: #f2f2f2;
      }

      .data-table tbody tr:nth-child(even) td {
        background: #ffffff;
      }

      .col-right {
        border-right: 1px solid #dcdfe3;
      }

      /* ── Separator ────────────────────────────────────── */
      .separator {
        border: none;
        border-top: 1px solid #dcdfe3;
        margin: 12px 0;
      }

      /* ── Closing text ─────────────────────────────────── */
      .closing-text {
        font-size: 12px;
        color: #000000;
        line-height: 1.333;
        margin-bottom: 16px;
      }

      .text-bold {
        font-weight: 600;
      }

      /* ── Bloco final (Local → Assinatura) ───────────── */
      .final-block {
        break-inside: avoid;
        break-inside: avoid-page;
        page-break-inside: avoid;
        -webkit-column-break-inside: avoid;
      }

      /* ── Signature ────────────────────────────────────── */
      .signature-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        margin-top: 32px;
        max-width: 260px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
        break-inside: avoid;
        break-inside: avoid-page;
        page-break-inside: avoid;
        -webkit-column-break-inside: avoid;
      }

      .sig-image {
        max-width: 120px;
        max-height: 60px;
        object-fit: contain;
        display: block;
        margin-bottom: 4px;
      }

      .sig-line {
        width: 100%;
        border: none;
        border-top: 1px solid #dcdfe3;
        margin-bottom: 4px;
      }

      .sig-name {
        font-size: 12px;
        font-weight: 600;
        color: #111111;
        line-height: 1.333;
      }

      .sig-detail {
        font-size: 10px;
        color: #111111;
        line-height: 1.4;
      }

      /* ── Cabeçalho Customizado ────────────────────────── */
      .custom-header {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 8px;
        margin-bottom: 20px;
      }
      .custom-header-logo-wrap {
        display: flex;
      }
      .custom-header--left .custom-header-logo-wrap {
        justify-content: flex-start;
      }
      .custom-header--center .custom-header-logo-wrap {
        justify-content: center;
      }
      .custom-header--right .custom-header-logo-wrap {
        justify-content: flex-end;
      }
      .custom-header-logo {
        max-height: 80px;
        max-width: 200px;
        object-fit: contain;
        flex-shrink: 0;
      }
      .custom-header-content {
        font-size: 11px;
        line-height: 1.4;
        color: #111;
        text-align: center;
      }
      .custom-header-content p {
        margin: 0 0 4px 0;
      }
    </style>
  </head>
  <body>

    <!-- ── Header ────────────────────────────────────────── -->
    {{#if customHeader}}
      <div class='custom-header custom-header--{{customHeader.logoPosition}}'>
        {{#if customHeader.logoUrl}}
          <div class='custom-header-logo-wrap'>
            <img
              class='custom-header-logo'
              src='{{customHeader.logoUrl}}'
              alt='Logo'
            />
          </div>
        {{/if}}
        {{#if customHeader.contentHtml}}
          <div
            class='custom-header-content'
          >{{{customHeader.contentHtml}}}</div>
        {{/if}}
      </div>
    {{else}}
      <div class='page-header'>
        <h1 class='report-title'>LAUDO MÉDICO</h1>
        <span class='report-date'>Data: {{today}}</span>
      </div>
    {{/if}}

    <!-- ── Dados do Paciente ──────────────────────────────── -->
    <div class='section'>
      <div class='section-heading'>
        <span class='section-title'>Dados do paciente</span>
      </div>
      <div class='patient-grid'>
        {{#if patientName}}
          <div class='patient-row'>
            <span class='patient-label'>Nome:</span>
            <span class='patient-value'>{{patientName}}</span>
          </div>
        {{/if}}
        {{#if patientBirthDate}}
          <div class='patient-row'>
            <span class='patient-label'>Data de Nascimento:</span>
            <span class='patient-value'>{{patientBirthDate}}</span>
          </div>
        {{/if}}
        {{#if patientRg}}
          <div class='patient-row'>
            <span class='patient-label'>RG:</span>
            <span class='patient-value'>{{patientRg}}</span>
          </div>
        {{/if}}
        {{#if patientCpf}}
          <div class='patient-row'>
            <span class='patient-label'>CPF:</span>
            <span class='patient-value'>{{patientCpf}}</span>
          </div>
        {{/if}}
        {{#if patientAddress}}
          <div class='patient-row'>
            <span class='patient-label'>Endereço:</span>
            <span class='patient-value'>{{patientAddress}}</span>
          </div>
        {{/if}}
        {{#if patientZipCode}}
          <div class='patient-row'>
            <span class='patient-label'>CEP:</span>
            <span class='patient-value'>{{patientZipCode}}</span>
          </div>
        {{/if}}
        {{#if patientPhone}}
          <div class='patient-row'>
            <span class='patient-label'>Telefone:</span>
            <span class='patient-value'>{{patientPhone}}</span>
          </div>
        {{/if}}
        {{#if patientHealthPlan}}
          <div class='patient-row'>
            <span class='patient-label'>Convênio:</span>
            <span class='patient-value'>{{patientHealthPlan}}</span>
          </div>
        {{/if}}
      </div>
    </div>

    <!-- ── Seções dinâmicas do laudo ──────────────────────── -->
    {{#if sections}}
      {{#each sections}}
        <div class='section'>
          <div class='section-heading'>
            <span class='section-title'>{{{title}}}</span>
          </div>
          <div class='body-text'>{{{description}}}</div>
        </div>
      {{/each}}
    {{else}}
      <!-- ── Histórico e Diagnóstico (legado) ─────────────── -->
      {{#if historyAndDiagnosis}}
        <div class='section'>
          <div class='section-heading'>
            <span class='section-title'>Histórico e diagnóstico</span>
          </div>
          <p class='body-text'>{{historyAndDiagnosis}}</p>
        </div>
      {{/if}}
    {{/if}}

    <!-- ── Imagens de Exame ────────────────────────────────── -->
    {{#if examImages}}
      <div class='section'>
        <div class='images-grid'>
          {{#each examImages}}
            <img class='exam-image' src='{{this}}' alt='Imagem do exame' />
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- ── Conduta (legado) ─────────────────────────────────── -->
    {{#unless sections}}
      {{#if conduct}}
        <div class='section'>
          <div class='section-heading'>
            <span class='section-title'>Conduta</span>
          </div>
          <p class='body-text'>{{conduct}}</p>
        </div>
      {{/if}}
    {{/unless}}

    <!-- ── Procedimentos Solicitados (TUSS) ───────────────── -->
    {{#if procedures.length}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Procedimento solicitado</span>
        </div>
        <table class='data-table'>
          <thead>
            <tr>
              <th style='width:55%' class='col-right'>Procedimentos</th>
              <th style='width:30%' class='col-right'>TUSS</th>
              <th style='width:15%'>Quantidade</th>
            </tr>
          </thead>
          <tbody>
            {{#each procedures}}
              <tr>
                <td class='col-right'>{{name}}</td>
                <td class='col-right'>{{tussCode}}</td>
                <td>{{quantity}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    <!-- ── Material Solicitado (OPME) ────────────────────── -->
    {{#if opmeItems.length}}
      <div class='section'>
        <div class='section-heading'>
          <span class='section-title'>Material solicitado</span>
        </div>
        <table class='data-table'>
          <thead>
            <tr>
              <th style='width:50%' class='col-right'>Material</th>
              <th style='width:20%' class='col-right'>Fabricantes</th>
              <th style='width:20%' class='col-right'>Fornecedores</th>
              <th style='width:10%'>Quantidade</th>
            </tr>
          </thead>
          <tbody>
            {{#each opmeItems}}
              <tr>
                <td class='col-right'>{{name}}</td>
                <td class='col-right'>{{#if
                    fabricantesText
                  }}{{fabricantesText}}{{else}}—{{/if}}</td>
                <td class='col-right'>{{#if
                    fornecedoresText
                  }}{{fornecedoresText}}{{else}}—{{/if}}</td>
                <td>{{quantity}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    <!-- ── Fabricantes e Fornecedores ─────────────────────── -->
    {{#if fabricantesText}}
      <p class='closing-text'>
        <span class='text-bold'>Fabricantes:</span>
        {{fabricantesText}}
      </p>
    {{/if}}
    {{#if fornecedoresText}}
      <p class='closing-text'>
        <span class='text-bold'>Fornecedores:</span>
        {{fornecedoresText}}
      </p>
    {{/if}}

    {{#if hasSeparator}}
      <hr class='separator' />
    {{/if}}

    <div class='final-block'>
      <!-- ── Local ──────────────────────────────────────────── -->
      {{#if localText}}
        <p class='closing-text'>
          <span class='text-bold'>Local:</span>
          {{localText}}
        </p>
      {{/if}}

      <!-- ── Encerramento ────────────────────────────────────── -->
      <p class='closing-text'>Colocando-me a disposição para maiores
        informações,</p>

      <!-- ── Assinatura ─────────────────────────────────────── -->
      <div class='signature-block'>
        {{#if doctorSignatureUrl}}
          <img
            class='sig-image'
            src='{{doctorSignatureUrl}}'
            alt='Assinatura do médico'
          />
        {{/if}}
        <hr class='sig-line' />
        <span class='sig-name'>{{doctorName}}</span>
        {{#if doctorSpecialty}}<span
            class='sig-detail'
          >{{doctorSpecialty}}</span>{{/if}}
        {{#if doctorCrm}}<span class='sig-detail'>{{doctorCrm}}</span>{{/if}}
      </div>
    </div>

  </body>
</html>